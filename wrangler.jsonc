{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "personal-agent",
	"main": "src/index.ts",
	"compatibility_date": "2026-06-08",
	"compatibility_flags": ["nodejs_compat"],
	"observability": {
		"enabled": true,
	},
	"upload_source_maps": true,

	// Workers AI — gives us `this.env.AI`. `remote: true` because there is no
	// local AI emulator: even `wrangler dev` runs inference on your real account.
	"ai": {
		"binding": "AI",
		"remote": true,
	},

	// Register PersonalAgent as a Durable Object. Each conversation instance is one
	// DO with its own SQLite storage. `getAgentByName(env.PersonalAgent, ...)` uses this.
	"durable_objects": {
		"bindings": [{ "name": "PersonalAgent", "class_name": "PersonalAgent" }],
	},

	// Agents/Think store state in SQLite, so the class must be a SQLite-backed DO.
	// Never edit a migration once shipped — only add new tags (v2, v3, ...).
	"migrations": [{ "tag": "v1", "new_sqlite_classes": ["PersonalAgent"] }],

	// Declare secret NAMES (not values) so `wrangler types` puts them in `Env`
	// without sniffing .env, and `wrangler dev` warns if any are missing. Set the
	// values via .env locally and `wrangler secret put` in production.
	"secrets": {
		"required": ["TELEGRAM_BOT_TOKEN", "TELEGRAM_BOT_USERNAME", "TELEGRAM_WEBHOOK_SECRET_TOKEN", "TAVILY_API_KEY", "GITHUB_TOKEN"],
	},
}
