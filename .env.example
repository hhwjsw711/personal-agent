# Copy to .env for local dev. The Deploy to Cloudflare button reads these keys
# to prompt for secrets. Leave blank for capabilities you don't use.

# Telegram — create a bot with @BotFather (https://t.me/BotFather)
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
# Any long random string (e.g. `openssl rand -hex 32`)
TELEGRAM_WEBHOOK_SECRET_TOKEN=

# Tavily web search — https://tavily.com
TAVILY_API_KEY=

# GitHub MCP — fine-grained PAT with repo/content scopes
# Create at https://github.com/settings/tokens?type=beta
GITHUB_TOKEN=
